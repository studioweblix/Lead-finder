# ---------------------------------------------------------------------------
# Diese Datei nach ".env.local" kopieren und mit echten Werten füllen:
#   cp .env.example .env.local
#
# WICHTIG: .env.local NIEMALS in Git committen (steht bereits in .gitignore).
# ---------------------------------------------------------------------------

# Google Places API Key (Google Cloud Console -> APIs & Services -> Credentials)
# Die "Places API (New)" muss im Projekt aktiviert und Billing eingerichtet sein.
GOOGLE_PLACES_API_KEY=

# Supabase Projekt-URL (Supabase Dashboard -> Project Settings -> Data API)
LEADS_SUPABASE_URL=

# Supabase Service Role Key (Supabase Dashboard -> Project Settings -> API Keys)
# Achtung: Service Key hat vollen Schreibzugriff -> geheim halten.
LEADS_SUPABASE_SERVICE_KEY=
